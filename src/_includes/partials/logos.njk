<section class="logos" aria-label="Past clients">
  <div class="container">
    <p class="logos-label">Trusted by leaders at</p>
    <div class="logos-grid">
      {% for client in site.clients %}
        <a class="logo-item" href="{{ client.url }}" rel="noopener" target="_blank" title="{{ client.name }} · {{ client.country }} — visit website" aria-label="{{ client.name }} (opens in new tab)">
          <img class="logo-img"
               src="https://logo.clearbit.com/{{ client.domain }}?size=200"
               alt="{{ client.name }}"
               loading="lazy"
               decoding="async"
               width="200" height="60"
               onerror="this.replaceWith(Object.assign(document.createElement('span'),{className:'logo-fallback',textContent:this.alt}));">
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Past clients of Abraham Otieno",
  "itemListElement": [
    {% for client in site.clients %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": { "@type": "Organization", "name": "{{ client.name }}", "url": "{{ client.url }}", "address": { "@type": "PostalAddress", "addressCountry": "{{ client.country }}" } }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
