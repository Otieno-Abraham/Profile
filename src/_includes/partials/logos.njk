<section class="logos" aria-label="Past clients">
  <div class="container">
    <p class="logos-label">Trusted by leaders at</p>
    <div class="logos-grid">
      {% for client in site.clients %}
        {% if client.url %}
        <a class="logo-item" href="{{ client.url }}" rel="noopener" target="_blank" title="{{ client.name }} · {{ client.country }} — visit website" aria-label="{{ client.name }} (opens in new tab)">
          {% if client.logo %}
          <span class="logo-card"><img class="logo-img" src="{{ client.logo }}" alt="{{ client.name }}" loading="lazy" width="170" height="85"></span>
          {% else %}
          <span class="logo-fallback">{{ client.name }}</span>
          {% endif %}
        </a>
        {% else %}
        <span class="logo-item" title="{{ client.name }} · {{ client.country }}">
          {% if client.logo %}
          <span class="logo-card"><img class="logo-img" src="{{ client.logo }}" alt="{{ client.name }}" loading="lazy" width="170" height="85"></span>
          {% else %}
          <span class="logo-fallback">{{ client.name }}</span>
          {% endif %}
        </span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Past clients of Abraham Otieno",
  "itemListElement": [
    {% for client in site.clients %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": { "@type": "Organization", "name": "{{ client.name }}"{% if client.url %}, "url": "{{ client.url }}"{% endif %}, "address": { "@type": "PostalAddress", "addressCountry": "{{ client.country }}" } }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
