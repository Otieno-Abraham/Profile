<section class="logos" aria-label="Past clients">
  <div class="container">
    <p class="logos-label">Trusted by leaders at</p>
    <div class="logos-grid">
      {% for client in site.clients %}
        {% if client.url %}
          <a class="logo-item" href="{{ client.url }}" rel="noopener" target="_blank" title="{{ client.name }} · {{ client.country }} — visit website">{{ client.name }}</a>
        {% else %}
          <span class="logo-item" title="{{ client.name }} · {{ client.country }}">{{ client.name }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Past clients of Abraham Otieno",
  "itemListElement": [
    {% for client in site.clients %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": { "@type": "Organization", "name": "{{ client.name }}"{% if client.url %}, "url": "{{ client.url }}"{% endif %}, "address": { "@type": "PostalAddress", "addressCountry": "{{ client.country }}" } }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
