<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-brand">
          <img src="/brand/logo-mark-dark.svg" alt="" width="28" height="28">
          <span>{{ site.name }}</span>
        </div>
        <p style="font-size:var(--fs-small); margin-bottom:var(--space-4); max-width:36ch;">
          Executive Assistant, Chief of Staff &amp; Operations Partner. Based in {{ site.city }}, {{ site.country }}, supporting founders, CEOs, and operators worldwide.
        </p>
        <p style="font-size:var(--fs-small);">
          <a href="mailto:{{ site.email }}">{{ site.email }}</a><br>
          <a href="{{ site.whatsapp }}" rel="noopener">WhatsApp · {{ site.phoneDisplay }}</a>
        </p>
        <address style="font-size:var(--fs-small); font-style:normal; margin-top:var(--space-3);">
          {{ site.streetAddress }}<br>{{ site.city }}, {{ site.country }}
        </address>
      </div>

      <div class="footer-col">
        <h4>Site</h4>
        <ul>
          {% for item in site.nav %}
            <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endfor %}
          <li><a href="/faq/">FAQ</a></li>
          <li><a href="/portfolio/">Portfolio</a></li>
          <li><a href="/cv/">CV / Résumé</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Hire me as</h4>
        <ul>
          {% for p in site.rolePages %}
            <li><a href="{{ p.url }}">{{ p.label }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Connect</h4>
        <ul>
          <li><a href="{{ site.linkedin }}" rel="noopener">LinkedIn</a></li>
          <li><a href="{{ site.upwork }}" rel="noopener">Upwork</a></li>
          <li><a href="{{ site.facebook }}" rel="noopener">Facebook</a></li>
          <li><a href="{{ site.whatsapp }}" rel="noopener">WhatsApp</a></li>
          <li><a href="mailto:{{ site.email }}">Email</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {% year %} {{ site.name }}. All rights reserved.</span>
      <span>Built in {{ site.city }}. Available worldwide.</span>
    </div>
  </div>
</footer>
