<header class="site-header">
  <div class="container nav">
    <a href="/" class="brand" aria-label="{{ site.name }} — home">
      <span class="brand-avatar"><img src="/abu.jpg" alt="" loading="eager" width="36" height="36"></span>
      <span>
        <span class="brand-name">{{ site.name }}</span>
        <span class="brand-role">Executive Assistant · Nairobi</span>
      </span>
    </a>

    <ul class="nav-links" role="navigation" aria-label="Primary">
      {% for item in site.nav %}
        {% if not item.primary %}
          <li><a href="{{ item.url }}" {% if pageKey == item.key %}aria-current="page"{% endif %}>{{ item.label }}</a></li>
        {% endif %}
      {% endfor %}
      <li><a href="/booking/" class="btn btn-primary" style="min-height:40px; padding:0 1rem; font-size:0.9rem;">Book a call</a></li>
    </ul>

    <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer" style="display:inline-flex;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="nav-drawer" id="nav-drawer" data-nav-drawer data-open="false" aria-label="Mobile menu">
    <ul>
      {% for item in site.nav %}
        <li><a href="{{ item.url }}" {% if pageKey == item.key %}aria-current="page"{% endif %}>{{ item.label }}</a></li>
      {% endfor %}
    </ul>
  </nav>
</header>

<style>
  /* Hide hamburger on desktop, show desktop nav links */
  @media (min-width: 900px) {
    .nav-toggle { display: none !important; }
  }
</style>
