<!DOCTYPE html>
<html lang="en-KE" data-page="{{ pageKey or 'page' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#150D07">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <meta name="author" content="{{ site.name }}">
  <link rel="canonical" href="{{ site.baseUrl }}{{ page.url }}">

  {% if noindex %}<meta name="robots" content="noindex, follow">
  {% else %}<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">{% endif %}

  {# Hreflang #}
  <link rel="alternate" hreflang="en-ke" href="{{ site.baseUrl }}{{ page.url }}">
  <link rel="alternate" hreflang="en" href="{{ site.baseUrl }}{{ page.url }}">
  <link rel="alternate" hreflang="x-default" href="{{ site.baseUrl }}{{ page.url }}">

  {# Geo #}
  <meta name="geo.placename" content="{{ site.city }}, {{ site.country }}">
  <meta name="geo.region" content="{{ site.region }}">
  <meta name="geo.position" content="{{ site.geo.lat }};{{ site.geo.lng }}">
  <meta name="ICBM" content="{{ site.geo.lat }}, {{ site.geo.lng }}">

  {# Open Graph — branded 1200x630 card is the default; pages may override via ogImage #}
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  <meta property="og:url" content="{{ site.baseUrl }}{{ page.url }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ site.name }} — {{ site.role }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta property="og:image" content="{{ site.baseUrl }}{{ ogImage or '/og-default.jpg' }}">
  <meta property="og:image:width" content="{{ ogImageWidth or 1200 }}">
  <meta property="og:image:height" content="{{ ogImageHeight or 630 }}">
  <meta property="og:image:alt" content="{{ ogImageAlt or (site.name + ' — Executive Assistant, Chief of Staff & Operations Partner in Nairobi, Kenya') }}">

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle or title }}">
  <meta name="twitter:description" content="{{ ogDescription or description }}">
  <meta name="twitter:image" content="{{ site.baseUrl }}{{ ogImage or '/og-default.jpg' }}">

  {# Favicon — branded AO monogram #}
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

  {# Fonts — preload brand typefaces #}
  <link rel="preload" href="/assets/fonts/space-grotesk.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/jetbrains-mono.woff2" as="font" type="font/woff2" crossorigin>

  {# Stylesheets — preload critical, swap in full #}
  <link rel="preload" href="/assets/css/style.css" as="style">
  <link rel="stylesheet" href="/assets/css/style.css">

  {# Schema: Person + ProfessionalService — present on every page so Google ties pages to the entity #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "{{ site.baseUrl }}/#person",
        "name": "{{ site.name }}",
        "jobTitle": "{{ site.role }}",
        "description": "Abraham Otieno is a Nairobi, Kenya-based Executive Assistant, Chief of Staff, and Operations Partner who supports founders, CEOs, and leadership teams remotely across East Africa, Europe, and the United States.",
        "url": "{{ site.baseUrl }}",
        "image": "{{ site.baseUrl }}/abu.jpg",
        "telephone": "{{ site.phone }}",
        "email": "{{ site.email }}",
        "nationality": { "@type": "Country", "name": "Kenya" },
        "sameAs": [
          "{{ site.linkedin }}",
          "{{ site.upwork }}",
          "{{ site.facebook }}",
          "{{ site.whatsapp }}"
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ site.streetAddress }}",
          "addressLocality": "{{ site.city }}",
          "addressRegion": "{{ site.addressRegion }}",
          "postalCode": "{{ site.postalCode }}",
          "addressCountry": "{{ site.countryCode }}"
        },
        "worksFor": { "@id": "{{ site.baseUrl }}/#business" },
        "knowsAbout": [
          "Executive Assistance", "Virtual Executive Assistant", "Chief of Staff",
          "Virtual Chief of Staff", "Fractional Chief of Staff", "Operations Management",
          "Remote Operations Management", "Business Operations", "Startup Operations",
          "Executive Communication", "Stakeholder Coordination", "Operations Systems",
          "Calendar Management", "Inbox Management", "Travel Logistics",
          "Market Entry", "Joint Venture Coordination", "CRM Setup",
          "Workflow Automation", "Remote Team Leadership", "Board Preparation"
        ],
        "hasOccupation": {
          "@type": "Occupation",
          "name": "Executive Assistant",
          "alternateName": [
            {% for r in site.roles %}"{{ r }}"{% if not loop.last %}, {% endif %}{% endfor %}
          ],
          "occupationLocation": [
            {"@type": "City", "name": "Nairobi"},
            {"@type": "Country", "name": "Kenya"},
            {"@type": "AdministrativeArea", "name": "East Africa"},
            {"@type": "AdministrativeArea", "name": "Worldwide Remote"}
          ],
          "skills": "Executive Communication, Stakeholder Coordination, Operations Systems, Calendar Management, CRM Setup, Market Entry, Joint Venture Coordination, Document Control, Multi-timezone Team Management, Board Preparation, Inbox Management, Travel Logistics"
        },
        "seeks": {
          "@type": "Demand",
          "name": "Executive Assistant, Chief of Staff, or Operations Partner role",
          "description": "Available for Executive Assistant, Virtual Executive Assistant, Chief of Staff, Virtual Chief of Staff, Fractional Chief of Staff, Operations Manager, and Operations Partner engagements with founders, CEOs, and leadership teams worldwide."
        },
        "potentialAction": {
          "@type": "HireAction",
          "target": "{{ site.baseUrl }}/booking/",
          "name": "Book a free consultation"
        }
      },
      {
        "@type": "ProfessionalService",
        "@id": "{{ site.baseUrl }}/#business",
        "name": "{{ site.name }} — Executive Assistant & Chief of Staff Services",
        "description": "Executive assistant, chief of staff, and operations partner services for founders, CEOs, and operators. Virtual EA, fractional chief of staff support, operations systems, market entry, stakeholder coordination. Based in Nairobi, Kenya, serving worldwide.",
        "url": "{{ site.baseUrl }}",
        "image": "{{ site.baseUrl }}/abu.jpg",
        "telephone": "{{ site.phone }}",
        "email": "{{ site.email }}",
        "priceRange": "$$",
        "areaServed": [
          {% for area in site.serviceAreas %}{"@type": "Place", "name": "{{ area }}"}{% if not loop.last %},{% endif %}{% endfor %}
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ site.streetAddress }}",
          "addressLocality": "{{ site.city }}",
          "addressRegion": "{{ site.addressRegion }}",
          "postalCode": "{{ site.postalCode }}",
          "addressCountry": "{{ site.countryCode }}"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": {{ site.geo.lat }},
          "longitude": {{ site.geo.lng }}
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        "founder": { "@id": "{{ site.baseUrl }}/#person" },
        "serviceType": [
          "Executive Assistant Services",
          "Virtual Executive Assistant",
          "Chief of Staff Support",
          "Virtual Chief of Staff",
          "Fractional Chief of Staff",
          "Operations Management",
          "Fractional Operations Partner",
          "Operations Consulting",
          "Market Entry Support"
        ]
      }{% if breadcrumbs %},
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {% for crumb in breadcrumbs %}
          {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "name": "{{ crumb.name }}",
            "item": "{{ site.baseUrl }}{{ crumb.url }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }{% endif %}{% if reviews %},
      {
        "@type": "Product",
        "@id": "{{ site.baseUrl }}/#service-product",
        "name": "Executive Assistant & Chief of Staff Services by Abraham Otieno",
        "description": "Virtual EA, Chief of Staff, and operations support for founders worldwide.",
        "brand": { "@id": "{{ site.baseUrl }}/#person" },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5",
          "bestRating": "5",
          "reviewCount": "{{ site.testimonials | length }}"
        },
        "review": [
          {% for r in site.testimonials %}
          {
            "@type": "Review",
            "reviewRating": { "@type": "Rating", "ratingValue": "{{ r.rating }}", "bestRating": "5" },
            "author": { "@type": "Person", "name": "{{ r.author }}", "jobTitle": "{{ r.title }}", "worksFor": { "@type": "Organization", "name": "{{ r.company }}" } },
            "reviewBody": {{ r.quote | dump | safe }},
            "datePublished": "{{ r.datePublished }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }{% endif %}{% if extraSchema %},
      {{ extraSchema | safe }}{% endif %}
    ]
  }
  </script>

  {% if faq %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq %}
      {
        "@type": "Question",
        "name": {{ item.q | dump | safe }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  {# BlogPosting schema — blog articles only (not the blog index) #}
  {% if tags and "post" in tags and page.url != "/blog/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | dump | safe }},
    "description": {{ description | dump | safe }},
    "image": "{{ site.baseUrl }}{{ ogImage or '/og-default.jpg' }}",
    "datePublished": "{{ page.date | isoDate }}",
    "dateModified": "{{ page.date | isoDate }}",
    "author": { "@type": "Person", "name": "{{ site.name }}", "url": "{{ site.baseUrl }}/about/" },
    "publisher": { "@id": "{{ site.baseUrl }}/#person" },
    "mainEntityOfPage": "{{ site.baseUrl }}{{ page.url }}"{% if keywords %},
    "keywords": "{{ keywords }}"{% endif %}
  }
  </script>
  {% endif %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>

  {% include "partials/header.njk" %}

  {% include "partials/breadcrumbs.njk" %}

  <main id="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}
  {% include "partials/fab-whatsapp.njk" %}

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
